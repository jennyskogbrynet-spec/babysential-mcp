# Babysential MCP Server — Environment Variables
# Copy to .env.local for development

# Optional: Babysential API key for live data (not required for static data mode)
# TODO: Generate at https://babysential.com/dashboard/api-keys
BABYSENTIAL_API_KEY=sk-your-key-here

# API base URL
BABYSENTIAL_API_BASE_URL=https://babysential.com

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# Node environment
NODE_ENV=development
